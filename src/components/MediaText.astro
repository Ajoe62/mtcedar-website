---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  alt: string;
  eyebrow?: string;
  title: string;
  reverse?: boolean;
  background?: string;
  sizes?: string;
}

const {
  image,
  alt,
  eyebrow,
  title,
  reverse = false,
  background,
  sizes = '(max-width: 820px) 92vw, 46vw',
} = Astro.props;
---
<section class={`mediatext${reverse ? ' reverse' : ''}`} style={background ? `background:${background}` : undefined}>
  <div class="wrap mt-grid">
    <div class="mt-media">
      <Image src={image} alt={alt} widths={[480, 768, 1100]} sizes={sizes} format="webp" quality={74} loading="lazy" />
    </div>
    <div class="mt-body">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h2>{title}</h2>
      <div class="mt-copy"><slot /></div>
    </div>
  </div>
</section>
