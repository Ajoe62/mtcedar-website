---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  alt: string;
  eyebrow?: string;
  title: string;
}

const { image, alt, eyebrow, title } = Astro.props;
---
<section class="fullbleed">
  <div class="fb-media" aria-hidden="true">
    <Image src={image} alt={alt} widths={[768, 1280, 1672]} sizes="100vw" format="webp" quality={72} loading="lazy" />
  </div>
  <div class="fb-overlay" aria-hidden="true"></div>
  <div class="fb-content wrap">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h2>{title}</h2>
    <slot />
  </div>
</section>
