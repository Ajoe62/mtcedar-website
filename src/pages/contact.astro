---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Contact — Mt Cedar British International School"
  description="Get in touch with Mt Cedar British International School, Benin City. Address, phone numbers, email and an enquiry form — we’d love to hear from your family."
  active="contact"
>

<section class="page-hero">
  <div class="wrap">
    <p class="eyebrow">Contact Us</p>
    <h1>We’d love to hear from you.</h1>
    <p>Whether you’re enquiring about a place or arranging a visit, our door — and inbox — is open.</p>
  </div>
</section>

<section>
  <div class="wrap contact-grid">
    <div>
      <p class="eyebrow">Reach the School</p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.3rem);margin:.5rem 0 1.4rem">Visit, call or email.</h2>
      <div class="cinfo">
        <div class="row">
          <div class="ic"><svg viewBox="0 0 24 24" width="22" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 21s-7-5.2-7-11a7 7 0 0 1 14 0c0 5.8-7 11-7 11Z"/><circle cx="12" cy="10" r="2.6"/></svg></div>
          <div>
            <h4>Address</h4>
            <a href="https://maps.google.com/?q=7+Saturday+Imasuen+Street+Obaretin+Ikpoba-Okha+Benin+City" target="_blank" rel="noopener">7 Saturday Imasuen Street, Obaretin Community, Ikpoba-Okha LGA, Benin City, Edo State</a>
          </div>
        </div>
        <div class="row">
          <div class="ic"><svg viewBox="0 0 24 24" width="22" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2 4.2 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1.9.4 1.8.7 2.6a2 2 0 0 1-.5 2.1L8.1 9.6a16 16 0 0 0 6 6l1.2-1.2a2 2 0 0 1 2.1-.5c.8.3 1.7.6 2.6.7A2 2 0 0 1 22 16.9Z"/></svg></div>
          <div>
            <h4>Phone</h4>
            <a href="tel:08056733071">0805 673 3071</a><br />
            <a href="tel:09043729659">0904 372 9659</a>
          </div>
        </div>
        <div class="row">
          <div class="ic"><svg viewBox="0 0 24 24" width="22" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg></div>
          <div>
            <h4>Email</h4>
            <a href="mailto:mtcedarbritishinternationalsch@gmail.com">mtcedarbritishinternationalsch@gmail.com</a>
          </div>
        </div>
        <div class="row">
          <div class="ic"><svg viewBox="0 0 24 24" width="22" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></div>
          <div>
            <h4>Office Hours</h4>
            <p>Monday – Friday, 8:00am – 4:00pm</p>
          </div>
        </div>
      </div>
    </div>

    <div>
      <form class="cform" id="contactForm">
        <p class="eyebrow" style="margin-bottom:.4rem">Send a Message</p>
        <label for="cf-name">Your name</label>
        <input id="cf-name" name="name" type="text" placeholder="Jane Doe" required />
        <label for="cf-email">Email address</label>
        <input id="cf-email" name="email" type="email" placeholder="you@example.com" required />
        <label for="cf-phone">Phone (optional)</label>
        <input id="cf-phone" name="phone" type="tel" placeholder="0800 000 0000" />
        <label for="cf-message">How can we help?</label>
        <textarea id="cf-message" name="message" placeholder="Tell us about your child and what you’d like to know…" required></textarea>
        <button class="btn btn-gold" type="submit">Send Message <span class="arr">→</span></button>
      </form>
    </div>
  </div>
</section>

<section class="band">
  <div class="wrap">
    <p class="eyebrow" style="color:var(--gold-bright)">Admissions Open</p>
    <h2>Ready to take the next step?</h2>
    <p>Applications for the 2026/2027 session are open across all stages.</p>
    <div class="cta">
      <a class="btn btn-gold btn-lg" href="/admissions">Explore Admissions <span class="arr">→</span></a>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contactForm');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const name = (data.get('name') || '').toString();
      const email = (data.get('email') || '').toString();
      const phone = (data.get('phone') || '').toString();
      const message = (data.get('message') || '').toString();
      const subject = encodeURIComponent(`Website enquiry from ${name}`);
      const body = encodeURIComponent(
        `Name: ${name}\nEmail: ${email}\nPhone: ${phone}\n\n${message}`
      );
      window.location.href =
        `mailto:mtcedarbritishinternationalsch@gmail.com?subject=${subject}&body=${body}`;
    });
  }
</script>

</Layout>
