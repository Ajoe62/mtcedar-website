---
import Layout from '../layouts/Layout.astro';
import MediaText from '../components/MediaText.astro';
import { Image } from 'astro:assets';
import headPhoto from '../assets/images/head-of-school.jpg';
import storyPhoto from '../assets/images/culturalattireday.jpg';
---
<Layout
  title="About — Mt Cedar British International School"
  description="Meet Mt Cedar British International School: our philosophy, our values, and the story behind a British-curriculum school in Benin City committed to Excellence, Character and Growth."
  active="about"
>

<section class="page-hero">
  <div class="wrap">
    <p class="eyebrow">About the School</p>
    <h1>An education that shapes the whole child.</h1>
    <p>Grounded in strong values and reaching for real academic excellence — Mt Cedar gives children deep roots and room to rise.</p>
  </div>
</section>

<section class="welcome">
  <div class="wrap">
    <div class="photo">
      <Image src={headPhoto} alt="The Head of School at Mt Cedar British International School" widths={[480, 768, 1100]} sizes="(max-width: 820px) 92vw, 46vw" format="webp" quality={76} loading="lazy" />
    </div>
    <div>
      <p class="eyebrow">Welcome to Mt Cedar</p>
      <h2>A warm word from the Head of School.</h2>
      <blockquote>“Like the cedar it is named for, our school is built to give children deep roots and room to rise — grounded in strong values, reaching for real academic excellence.”</blockquote>
      <div class="signoff">The Head of School<small>Mt Cedar British International School</small></div>
    </div>
  </div>
</section>

<MediaText
  image={storyPhoto}
  alt="Mt Cedar pupils celebrating cultural attire day"
  eyebrow="Our Story"
  title="Named for the cedar — rooted deep, reaching high."
  reverse={true}
>
  <p>Mt Cedar British International School was founded on a simple conviction: that children flourish when high academic expectations are matched by genuine care for who they are becoming. We take our name from the cedar — a tree prized for standing firm through every season while growing tall and strong.</p>
  <p>Set in the Obaretin community of Ikpoba-Okha, Benin City, we bring the British curriculum to Edo State, taught by caring teachers in small, focused classes and adapted thoughtfully for our Nigerian context.</p>
  <div class="cta">
    <a class="btn btn-cedar" href="/admissions">Explore Admissions <span class="arr">→</span></a>
    <a class="btn btn-outline" href="/contact">Arrange a Visit</a>
  </div>
</MediaText>

<section class="values" style="background:var(--ivory-2)">
  <div class="wrap">
    <div class="sec-head"><p class="eyebrow">Our Promise</p><h2>Three commitments, on our crest and in our classrooms.</h2><p>The emblems on our shield are not decoration — they name what we set out to give every child who joins us.</p></div>
    <div class="values-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.4rem;margin-top:2.6rem">
      <div class="vcard">
        <div class="ic"><svg viewBox="0 0 24 24" width="26" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 3 2 8l10 5 10-5-10-5Z"/><path d="M6 10v4c0 1.5 2.7 3 6 3s6-1.5 6-3v-4"/><path d="M22 8v5"/></svg></div>
        <h3>Excellence</h3>
        <p>High academic standards and the habits — focus, effort, curiosity — that make them last.</p>
      </div>
      <div class="vcard">
        <div class="ic"><svg viewBox="0 0 24 24" width="26" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 2c1.5 3-1.5 4-1.5 6.5A2.5 2.5 0 0 0 14 8c1 2.5 0 4-2 5.5"/><path d="M8 13c-1 3 1 6 4 6s5-3 4-6"/><path d="M9 22h6"/></svg></div>
        <h3>Character</h3>
        <p>A guiding flame of values — honesty, kindness and courage — carried into everything they do.</p>
      </div>
      <div class="vcard">
        <div class="ic"><svg viewBox="0 0 24 24" width="26" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 22V9"/><path d="M12 13c3.5 0 6-2 6-5.5C18 4 12 2 12 2S6 4 6 7.5C6 11 8.5 13 12 13Z"/></svg></div>
        <h3>Growth</h3>
        <p>Room to rise — like the cedar we are named for, each child rooted deep and reaching high.</p>
      </div>
    </div>
  </div>
</section>

<section class="band">
  <div class="wrap">
    <p class="eyebrow" style="color:var(--gold-bright)">Admissions Open</p>
    <h2>Come and see where your child will grow.</h2>
    <p>Applications for the 2026/2027 session are open across Early Years, Primary and Secondary. Arrange a visit and feel the Mt Cedar difference in person.</p>
    <div class="cta">
      <a class="btn btn-gold btn-lg" href="/admissions">Start an Enquiry <span class="arr">→</span></a>
      <a class="btn btn-ghost btn-lg" href="/contact">Contact the School</a>
    </div>
  </div>
</section>

</Layout>
