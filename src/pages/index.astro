---
import Layout from '../layouts/Layout.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import { Image } from 'astro:assets';
import welcomePhoto from '../assets/images/teacher-pupil-connection.jpg';
import newsAdmissions from '../assets/images/engagedlearners.jpg';
import newsFounders from '../assets/images/culturalattireday.jpg';
import newsScience from '../assets/images/sciencepupils.jpg';

const thumbSizes = '(max-width: 820px) 92vw, 30vw';
---
<Layout
  title="Mt Cedar British International School — Benin City"
  active=""
>

<HeroCarousel>
  <p class="eyebrow">British International School · Benin City</p>
  <h1>Where character takes root and <em>excellence</em> grows.</h1>
  <p class="lead">A British-curriculum education for the nursery, primary and secondary years — nurturing confident, principled young people in the heart of Edo State.</p>
  <div class="cta">
    <a class="btn btn-gold btn-lg" href="/admissions">Begin an Application <span class="arr">→</span></a>
    <a class="btn btn-ghost btn-lg" href="/about">Discover the School</a>
  </div>
  <div class="motto"><span></span>Committed to Excellence, Character and Growth</div>
</HeroCarousel>

<div class="facts">
  <div class="wrap">
    <div class="f"><b>British</b><span>Curriculum</span></div>
    <div class="f"><b>Nursery–Secondary</b><span>Every Stage</span></div>
    <div class="f"><b>Benin City</b><span>Edo State</span></div>
    <div class="f"><b>Open</b><span>Admissions 2026</span></div>
  </div>
</div>

<section class="welcome">
  <div class="wrap">
    <div class="photo">
      <Image src={welcomePhoto} alt="A Mt Cedar teacher supporting a pupil in class" widths={[480, 768, 1100]} sizes="(max-width: 820px) 92vw, 46vw" format="webp" quality={74} loading="lazy" />
    </div>
    <div>
      <p class="eyebrow">Welcome to Mt Cedar</p>
      <h2>An education that shapes the whole child.</h2>
      <blockquote>“Like the cedar it is named for, our school is built to give children deep roots and room to rise — grounded in strong values, reaching for real academic excellence.”</blockquote>
      <div class="signoff">The Head of School<small>Mt Cedar British International School</small></div>
      <div class="cta" style="margin-top:1.6rem">
        <a class="btn btn-cedar" href="/about">Read our story <span class="arr">→</span></a>
      </div>
    </div>
  </div>
</section>

<section class="values">
  <div class="wrap">
    <div class="sec-head"><p class="eyebrow">Our Promise</p><h2>Three commitments, on our crest and in our classrooms.</h2><p>The emblems on our shield are not decoration — they name what we set out to give every child who joins us.</p></div>
    <div class="values-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.4rem;margin-top:2.6rem">
      <div class="vcard">
        <div class="ic"><svg viewBox="0 0 24 24" width="26" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 3 2 8l10 5 10-5-10-5Z"/><path d="M6 10v4c0 1.5 2.7 3 6 3s6-1.5 6-3v-4"/><path d="M22 8v5"/></svg></div>
        <h3>Excellence</h3>
        <p>High academic standards and the habits — focus, effort, curiosity — that make them last.</p>
      </div>
      <div class="vcard">
        <div class="ic"><svg viewBox="0 0 24 24" width="26" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 2c1.5 3-1.5 4-1.5 6.5A2.5 2.5 0 0 0 14 8c1 2.5 0 4-2 5.5"/><path d="M8 13c-1 3 1 6 4 6s5-3 4-6"/><path d="M9 22h6"/></svg></div>
        <h3>Character</h3>
        <p>A guiding flame of values — honesty, kindness and courage — carried into everything they do.</p>
      </div>
      <div class="vcard">
        <div class="ic"><svg viewBox="0 0 24 24" width="26" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 22V9"/><path d="M12 13c3.5 0 6-2 6-5.5C18 4 12 2 12 2S6 4 6 7.5C6 11 8.5 13 12 13Z"/></svg></div>
        <h3>Growth</h3>
        <p>Room to rise — like the cedar we are named for, each child rooted deep and reaching high.</p>
      </div>
    </div>
  </div>
</section>

<section class="news">
  <div class="wrap">
    <div class="top">
      <div class="sec-head"><p class="eyebrow">News &amp; Events</p><h2>Life at Mt Cedar.</h2></div>
      <a class="btn btn-cedar" href="/news">View all news <span class="arr">→</span></a>
    </div>
    <div class="grid3">
      <article class="ncard"><div class="thumb"><Image src={newsAdmissions} alt="Engaged Mt Cedar learners in class" widths={[400, 640, 900]} sizes={thumbSizes} format="webp" quality={72} loading="lazy" /></div><div class="body"><span class="tag">Admissions</span><h3>2026/2027 admissions are now open</h3><p>Enrolment for the new session has begun across all stages. Book a visit to see the school for yourself.</p></div></article>
      <article class="ncard"><div class="thumb"><Image src={newsFounders} alt="Pupils in cultural attire celebrating together" widths={[400, 640, 900]} sizes={thumbSizes} format="webp" quality={72} loading="lazy" /></div><div class="body"><span class="tag">Event</span><h3>Founder’s Day &amp; cultural showcase</h3><p>A celebration of learning, character and community — pupils, parents and staff together.</p></div></article>
      <article class="ncard"><div class="thumb"><Image src={newsScience} alt="Young scientists at work" widths={[400, 640, 900]} sizes={thumbSizes} format="webp" quality={72} loading="lazy" /></div><div class="body"><span class="tag">Achievement</span><h3>Our pupils shine in the science fair</h3><p>Young scientists present projects rooted in curiosity, care and real-world problem solving.</p></div></article>
    </div>
  </div>
</section>

<section class="band">
  <div class="wrap">
    <p class="eyebrow" style="color:var(--gold-bright)">Admissions Open</p>
    <h2>Come and see where your child will grow.</h2>
    <p>Applications for the 2026/2027 session are open across Early Years, Primary and Secondary. Arrange a visit, meet our teachers, and feel the Mt Cedar difference in person.</p>
    <div class="cta">
      <a class="btn btn-gold btn-lg" href="/admissions">Start an Enquiry <span class="arr">→</span></a>
      <a class="btn btn-ghost btn-lg" href="/contact">Contact the School</a>
    </div>
  </div>
</section>

</Layout>
