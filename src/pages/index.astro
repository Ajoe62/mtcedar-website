<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Mt Cedar British International School — Benin City</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Mulish:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style is:global>
  :root{
    --cedar:#123c28;
    --cedar-deep:#0c2a1c;
    --gold:#c39630;
    --gold-bright:#e0b64a;
    --oxblood:#7c2230;
    --ivory:#f5f0e5;
    --ivory-2:#efe7d6;
    --ink:#16211b;
    --muted:#5c6a60;
    --line:rgba(18,60,40,.14);
    --display:'Fraunces',Georgia,serif;
    --body:'Mulish',system-ui,sans-serif;
  }
  *{box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{margin:0;font-family:var(--body);color:var(--ink);background:var(--ivory);line-height:1.6;-webkit-font-smoothing:antialiased}
  h1,h2,h3{font-family:var(--display);font-weight:600;line-height:1.1;margin:0}
  a{color:inherit;text-decoration:none}
  img{max-width:100%;display:block}
  .wrap{width:min(1160px,92vw);margin-inline:auto}
  .eyebrow{font-family:var(--body);font-weight:700;letter-spacing:.18em;text-transform:uppercase;font-size:.72rem;color:var(--gold)}

  /* utility bar */
  .util{background:var(--cedar-deep);color:#e7e0cf;font-size:.82rem}
  .util .wrap{display:flex;justify-content:space-between;align-items:center;gap:1rem;padding:.5rem 0}
  .util a{opacity:.9}
  .util .u-r{display:flex;gap:1.4rem;align-items:center}
  .util .apply{color:var(--cedar-deep);background:var(--gold-bright);padding:.28rem .8rem;border-radius:100px;font-weight:700;font-size:.78rem}
  @media(max-width:680px){.util .u-l span{display:none}}

  /* header */
  header.site{position:sticky;top:0;z-index:40;background:rgba(245,240,229,.92);backdrop-filter:blur(8px);border-bottom:1px solid var(--line)}
  header.site .wrap{display:flex;align-items:center;gap:1.2rem;padding:.7rem 0}
  .brand{display:flex;align-items:center;gap:.7rem}
  .brand img{width:46px;height:46px;border-radius:50%}
  .brand b{font-family:var(--display);font-weight:600;font-size:1.05rem;line-height:1.05;letter-spacing:.01em}
  .brand small{display:block;font-family:var(--body);font-weight:600;font-size:.66rem;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);margin-top:2px}
  nav.main{margin-left:auto;display:flex;gap:1.5rem;align-items:center;font-weight:600;font-size:.92rem}
  nav.main a{position:relative;padding:.2rem 0;color:var(--ink)}
  nav.main a::after{content:"";position:absolute;left:0;bottom:-3px;height:2px;width:0;background:var(--gold);transition:width .25s}
  nav.main a:hover::after{width:100%}
  .btn{display:inline-block;font-weight:700;border-radius:100px;padding:.6rem 1.25rem;font-size:.9rem;cursor:pointer;transition:transform .18s,box-shadow .18s}
  .btn-gold{background:var(--gold);color:#1a2318;box-shadow:0 1px 0 rgba(0,0,0,.08)}
  .btn-gold:hover{transform:translateY(-1px);box-shadow:0 8px 22px rgba(140,110,20,.28)}
  .btn-ghost{border:1.5px solid rgba(255,255,255,.5);color:#fff}
  .btn-ghost:hover{background:rgba(255,255,255,.1)}
  .menu-btn{display:none;margin-left:auto;background:none;border:1.5px solid var(--line);border-radius:8px;padding:.4rem .6rem;font-size:1.1rem}
  @media(max-width:940px){nav.main,header .btn-gold{display:none}.menu-btn{display:block}}

  /* hero */
  .hero{position:relative;background:
      radial-gradient(120% 90% at 85% -10%,rgba(195,150,48,.22),transparent 55%),
      linear-gradient(160deg,var(--cedar) 0%,var(--cedar-deep) 100%);
      color:#f3ecdb;overflow:hidden}
  .hero::before{content:"";position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,.05) 1px,transparent 1px);background-size:22px 22px;opacity:.5}
  .hero .wrap{position:relative;display:grid;grid-template-columns:1.15fr .85fr;gap:3rem;align-items:center;padding:4.6rem 0 4.8rem}
  .hero h1{font-size:clamp(2.5rem,5vw,4rem);font-weight:600;color:#fbf6ea;letter-spacing:-.01em}
  .hero h1 em{font-style:italic;color:var(--gold-bright)}
  .hero p.lead{font-size:1.12rem;color:#d9d0bd;max-width:42ch;margin:1.3rem 0 0}
  .hero .cta{display:flex;gap:.9rem;margin-top:2rem;flex-wrap:wrap}
  .motto{display:inline-flex;align-items:center;gap:.6rem;margin-top:2.2rem;font-size:.82rem;letter-spacing:.06em;color:#cdc4b0}
  .motto span{height:1px;width:34px;background:var(--gold)}
  .crest-card{position:relative;justify-self:center}
  .crest-ring{width:min(340px,72vw);aspect-ratio:1;border-radius:50%;
    background:radial-gradient(circle at 50% 40%,rgba(255,255,255,.06),transparent 70%);
    border:1px solid rgba(224,182,74,.35);display:grid;place-items:center;
    box-shadow:0 30px 60px rgba(0,0,0,.35),inset 0 0 0 10px rgba(224,182,74,.06)}
  .crest-ring::after{content:"";position:absolute;inset:-14px;border-radius:50%;border:1px dashed rgba(224,182,74,.28)}
  .crest-ring img{width:78%;border-radius:50%}
  @media(max-width:940px){.hero .wrap{grid-template-columns:1fr;text-align:center;padding:3.4rem 0}.hero .cta,.motto{justify-content:center}.crest-card{order:-1}.hero p.lead{margin-inline:auto}}

  /* facts strip */
  .facts{background:var(--gold);color:#20180a}
  .facts .wrap{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;padding:0}
  .facts .f{padding:1.5rem 1rem;text-align:center}
  .facts .f b{display:block;font-family:var(--display);font-size:1.5rem;font-weight:600;line-height:1}
  .facts .f span{font-size:.78rem;font-weight:700;letter-spacing:.09em;text-transform:uppercase;opacity:.72}
  @media(max-width:720px){.facts .wrap{grid-template-columns:repeat(2,1fr)}.facts .f{border-bottom:1px solid rgba(0,0,0,.08)}}

  /* section shells */
  section{padding:5rem 0}
  .sec-head{max-width:60ch}
  .sec-head h2{font-size:clamp(1.9rem,3.4vw,2.7rem);margin-top:.6rem}
  .sec-head p{color:var(--muted);font-size:1.05rem;margin-top:.8rem}

  /* welcome */
  .welcome{background:var(--ivory-2)}
  .welcome .wrap{display:grid;grid-template-columns:.9fr 1.1fr;gap:3rem;align-items:center}
  .welcome .photo{aspect-ratio:4/3;border-radius:14px;background:
      linear-gradient(135deg,#1a4d33,#0e3222);position:relative;overflow:hidden;
      box-shadow:0 24px 44px rgba(18,60,40,.22)}
  .welcome .photo span{position:absolute;inset:auto 1rem 1rem;color:rgba(255,255,255,.6);font-size:.78rem;letter-spacing:.05em}
  .welcome blockquote{font-family:var(--display);font-size:1.35rem;line-height:1.5;font-weight:500;margin:1.4rem 0 0;color:var(--cedar)}
  .signoff{margin-top:1.4rem;font-weight:700}.signoff small{display:block;color:var(--muted);font-weight:600}
  @media(max-width:820px){.welcome .wrap{grid-template-columns:1fr}}

  /* values (crest symbols) */
  .values .wrap{display:grid;grid-template-columns:repeat(3,1fr);gap:1.4rem;margin-top:2.6rem}
  .vcard{background:#fff;border:1px solid var(--line);border-radius:14px;padding:2rem 1.7rem;transition:transform .2s,box-shadow .2s}
  .vcard:hover{transform:translateY(-4px);box-shadow:0 18px 40px rgba(18,60,40,.12)}
  .vcard .ic{width:52px;height:52px;color:var(--cedar);background:rgba(195,150,48,.14);border-radius:12px;display:grid;place-items:center;margin-bottom:1.1rem}
  .vcard h3{font-size:1.35rem}
  .vcard p{color:var(--muted);margin:.5rem 0 0;font-size:.98rem}
  @media(max-width:820px){.values .wrap{grid-template-columns:1fr}}

  /* academics */
  .academics{background:var(--cedar);color:#eee6d4}
  .academics .sec-head h2{color:#fbf6ea}
  .academics .sec-head p{color:#c9c0ac}
  .academics .eyebrow{color:var(--gold-bright)}
  .prog{display:grid;grid-template-columns:repeat(3,1fr);gap:1.3rem;margin-top:2.6rem}
  .pcard{background:rgba(255,255,255,.04);border:1px solid rgba(224,182,74,.22);border-radius:14px;padding:1.9rem 1.6rem}
  .pcard .age{font-family:var(--display);color:var(--gold-bright);font-size:.95rem}
  .pcard h3{color:#fff;font-size:1.4rem;margin:.3rem 0 .7rem}
  .pcard p{color:#c9c0ac;font-size:.95rem;margin:0}
  .pcard a{display:inline-block;margin-top:1.1rem;color:var(--gold-bright);font-weight:700;font-size:.9rem}
  @media(max-width:820px){.prog{grid-template-columns:1fr}}

  /* news */
  .news .wrap>.top{display:flex;justify-content:space-between;align-items:flex-end;gap:1rem}
  .grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:1.4rem;margin-top:2.4rem}
  .ncard{border:1px solid var(--line);border-radius:14px;overflow:hidden;background:#fff;transition:transform .2s,box-shadow .2s}
  .ncard:hover{transform:translateY(-4px);box-shadow:0 18px 40px rgba(18,60,40,.12)}
  .ncard .thumb{aspect-ratio:16/10;background:linear-gradient(135deg,#20583c,#123c28)}
  .ncard:nth-child(2) .thumb{background:linear-gradient(135deg,#8c3b1e,#7c2230)}
  .ncard:nth-child(3) .thumb{background:linear-gradient(135deg,#b98a2b,#8a6415)}
  .ncard .body{padding:1.3rem 1.3rem 1.6rem}
  .ncard .tag{font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--gold)}
  .ncard h3{font-size:1.25rem;margin:.4rem 0 .5rem;line-height:1.2}
  .ncard p{color:var(--muted);font-size:.92rem;margin:0}
  @media(max-width:820px){.grid3{grid-template-columns:1fr}}

  /* admissions band */
  .band{background:linear-gradient(120deg,var(--oxblood),#5c1620);color:#fbeee4;text-align:center}
  .band .wrap{padding:4.4rem 0}
  .band h2{font-size:clamp(1.9rem,3.6vw,2.8rem);color:#fff}
  .band p{max-width:52ch;margin:1rem auto 0;color:#f0d9cf}
  .band .cta{margin-top:2rem;display:flex;gap:.9rem;justify-content:center;flex-wrap:wrap}

  /* footer */
  footer.site{background:var(--cedar-deep);color:#cfc7b4;font-size:.94rem}
  footer.site .wrap{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:2.4rem;padding:3.6rem 0 2rem}
  footer .brand b{color:#fbf6ea}
  footer h4{font-family:var(--body);text-transform:uppercase;letter-spacing:.12em;font-size:.75rem;color:var(--gold-bright);margin:0 0 1rem}
  footer a{display:block;padding:.24rem 0;color:#cfc7b4}
  footer a:hover{color:#fff}
  footer .fbrand p{margin:1rem 0 0;max-width:34ch;color:#a9a290}
  .foot-b{border-top:1px solid rgba(255,255,255,.1)}
  .foot-b .wrap{display:flex;justify-content:space-between;gap:1rem;padding:1.1rem 0;font-size:.82rem;color:#8f8877;flex-wrap:wrap}
  @media(max-width:820px){footer.site .wrap{grid-template-columns:1fr;gap:2rem}}

  @media(prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important;scroll-behavior:auto}}
  .reveal{opacity:0;transform:translateY(14px);animation:rise .7s ease forwards}
  @keyframes rise{to{opacity:1;transform:none}}
</style>
</head>
<body>

<div class="util">
  <div class="wrap">
    <div class="u-l"><span>📍 Benin City, Edo State &nbsp;·&nbsp; </span><a href="tel:08056733071">☎ 0805 673 3071</a></div>
    <div class="u-r">
      <a href="mailto:mtcedarbritishinternationalsch@gmail.com">mtcedarbritishinternationalsch@gmail.com</a>
      <a class="apply" href="#admissions">Apply Now</a>
    </div>
  </div>
</div>

<header class="site">
  <div class="wrap">
    <a class="brand" href="#">
      <img src="data:image/jpeg;base64," alt="Mt Cedar crest" />
      <span><b>Mt Cedar</b><small>British International School</small></span>
    </a>
    <nav class="main">
      <a href="#welcome">About</a>
      <a href="#academics">Academics</a>
      <a href="#admissions">Admissions</a>
      <a href="#life">School Life</a>
      <a href="#news">News</a>
      <a href="#contact">Contact</a>
    </nav>
    <a class="btn btn-gold" href="#admissions">Book a Visit</a>
    <button class="menu-btn" aria-label="Menu">☰</button>
  </div>
</header>

<section class="hero">
  <div class="wrap">
    <div class="reveal">
      <p class="eyebrow">British International School · Benin City</p>
      <h1>Where character takes root and <em>excellence</em> grows.</h1>
      <p class="lead">A British-curriculum education for the nursery, primary and secondary years — nurturing confident, principled young people in the heart of Edo State.</p>
      <div class="cta">
        <a class="btn btn-gold" href="#admissions">Begin an Application</a>
        <a class="btn btn-ghost" href="#welcome">Discover the School</a>
      </div>
      <div class="motto"><span></span>Committed to Excellence, Character and Growth</div>
    </div>
    <div class="crest-card reveal">
      <div class="crest-ring"><img src="data:image/jpeg;base64," alt="Mt Cedar British International School crest" /></div>
    </div>
  </div>
</section>

<div class="facts">
  <div class="wrap">
    <div class="f"><b>British</b><span>Curriculum</span></div>
    <div class="f"><b>Nursery–Secondary</b><span>Every Stage</span></div>
    <div class="f"><b>Benin City</b><span>Edo State</span></div>
    <div class="f"><b>Open</b><span>Admissions 2026</span></div>
  </div>
</div>

<section class="welcome" id="welcome">
  <div class="wrap">
    <div class="photo"><span>School photograph — to be added</span></div>
    <div>
      <p class="eyebrow">Welcome to Mt Cedar</p>
      <h2>An education that shapes the whole child.</h2>
      <blockquote>“Like the cedar it is named for, our school is built to give children deep roots and room to rise — grounded in strong values, reaching for real academic excellence.”</blockquote>
      <div class="signoff">The Head of School<small>Mt Cedar British International School</small></div>
    </div>
  </div>
</section>

<section class="values">
  <div class="wrap">
    <div class="sec-head"><p class="eyebrow">Our Promise</p><h2>Three commitments, on our crest and in our classrooms.</h2><p>The emblems on our shield are not decoration — they name what we set out to give every child who joins us.</p></div>
    <div class="wrap" style="width:100%">
      <div class="values-inner"></div>
    </div>
  </div>
</section>

<section class="academics" id="academics">
  <div class="wrap">
    <div class="sec-head"><p class="eyebrow">Academics</p><h2>A clear path from first steps to school leaver.</h2><p>The British curriculum, taught by caring teachers in small, focused classes, adapted thoughtfully for our Nigerian context.</p></div>
    <div class="prog">
      <div class="pcard"><div class="age">Ages 2–5</div><h3>Early Years</h3><p>A warm, play-led start where curiosity, language and confidence take shape through structured discovery.</p><a href="#">Explore Early Years →</a></div>
      <div class="pcard"><div class="age">Ages 5–11</div><h3>Primary</h3><p>Strong foundations in literacy, numeracy and enquiry, with specialist teaching in the arts, science and sport.</p><a href="#">Explore Primary →</a></div>
      <div class="pcard"><div class="age">Ages 11–16</div><h3>Secondary</h3><p>Rigorous, examination-ready study that stretches able minds and prepares students for the wider world.</p><a href="#">Explore Secondary →</a></div>
    </div>
  </div>
</section>

<section class="news" id="news">
  <div class="wrap">
    <div class="top">
      <div class="sec-head"><p class="eyebrow">News &amp; Events</p><h2>Life at Mt Cedar.</h2></div>
      <a class="btn btn-gold" href="#">View all news</a>
    </div>
    <div class="grid3">
      <article class="ncard"><div class="thumb"></div><div class="body"><span class="tag">Admissions</span><h3>2026/2027 admissions are now open</h3><p>Enrolment for the new session has begun across all stages. Book a visit to see the school for yourself.</p></div></article>
      <article class="ncard"><div class="thumb"></div><div class="body"><span class="tag">Event</span><h3>Founder’s Day &amp; cultural showcase</h3><p>A celebration of learning, character and community — pupils, parents and staff together.</p></div></article>
      <article class="ncard"><div class="thumb"></div><div class="body"><span class="tag">Achievement</span><h3>Our pupils shine in the science fair</h3><p>Young scientists present projects rooted in curiosity, care and real-world problem solving.</p></div></article>
    </div>
  </div>
</section>

<section class="band" id="admissions">
  <div class="wrap">
    <p class="eyebrow" style="color:var(--gold-bright)">Admissions Open</p>
    <h2>Come and see where your child will grow.</h2>
    <p>Applications for the 2026/2027 session are open across Early Years, Primary and Secondary. Arrange a visit, meet our teachers, and feel the Mt Cedar difference in person.</p>
    <div class="cta">
      <a class="btn btn-gold" href="#contact">Start an Enquiry</a>
      <a class="btn btn-ghost" href="tel:09043729659" style="border-color:rgba(255,255,255,.55)">Call 0904 372 9659</a>
    </div>
  </div>
</section>

<footer class="site" id="contact">
  <div class="wrap">
    <div class="fbrand">
      <div class="brand"><img src="data:image/jpeg;base64," alt="" style="width:44px;height:44px;border-radius:50%"/><span><b>Mt Cedar</b><small style="color:var(--gold-bright)">British International School</small></span></div>
      <p>Committed to Excellence, Character and Growth — a British-curriculum school in Benin City, Edo State.</p>
    </div>
    <div>
      <h4>Visit &amp; Contact</h4>
      <a href="#">7 Saturday Imasuen Street, Obaretin Community, Ikpoba-Okha LGA, Benin City, Edo State</a>
      <a href="tel:08056733071">0805 673 3071</a>
      <a href="tel:09043729659">0904 372 9659</a>
      <a href="mailto:mtcedarbritishinternationalsch@gmail.com">mtcedarbritishinternationalsch@gmail.com</a>
    </div>
    <div>
      <h4>Explore</h4>
      <a href="#welcome">About the School</a>
      <a href="#academics">Academics</a>
      <a href="#admissions">Admissions</a>
      <a href="#news">News &amp; Events</a>
    </div>
  </div>
  <div class="foot-b"><div class="wrap"><span>© 2026 Mt Cedar British International School</span><span>mtcedarbritishinternationalsch.com.ng</span></div></div>
</footer>

<script is:inline>
  // build value cards with crest-derived icons
  var vals=[
    {t:'Excellence',d:'High academic standards and the habits — focus, effort, curiosity — that make them last.',
     ic:'<svg viewBox="0 0 24 24" width="26" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 3 2 8l10 5 10-5-10-5Z"/><path d="M6 10v4c0 1.5 2.7 3 6 3s6-1.5 6-3v-4"/><path d="M22 8v5"/></svg>'},
    {t:'Character',d:'A guiding flame of values — honesty, kindness and courage — carried into everything they do.',
     ic:'<svg viewBox="0 0 24 24" width="26" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 2c1.5 3-1.5 4-1.5 6.5A2.5 2.5 0 0 0 14 8c1 2.5 0 4-2 5.5"/><path d="M8 13c-1 3 1 6 4 6s5-3 4-6"/><path d="M9 22h6"/></svg>'},
    {t:'Growth',d:'Room to rise — like the cedar we are named for, each child rooted deep and reaching high.',
     ic:'<svg viewBox="0 0 24 24" width="26" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 22V9"/><path d="M12 13c3.5 0 6-2 6-5.5C18 4 12 2 12 2S6 4 6 7.5C6 11 8.5 13 12 13Z"/></svg>'}
  ];
  var box=document.querySelector('.values-inner');
  box.style.cssText='display:grid;grid-template-columns:repeat(3,1fr);gap:1.4rem;margin-top:2.6rem';
  box.className='values-grid';
  vals.forEach(function(v){
    var el=document.createElement('div');el.className='vcard';
    el.innerHTML='<div class="ic">'+v.ic+'</div><h3>'+v.t+'</h3><p>'+v.d+'</p>';
    box.appendChild(el);
  });
  var mq=window.matchMedia('(max-width:820px)');
  function fix(){box.style.gridTemplateColumns=mq.matches?'1fr':'repeat(3,1fr)';}
  mq.addEventListener('change',fix);fix();
</script>
</body>
</html>
