---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="News & Events — Mt Cedar British International School"
  description="The latest news and events from Mt Cedar British International School, Benin City — admissions updates, celebrations and pupil achievements."
  active="news"
>

<section class="page-hero">
  <div class="wrap">
    <p class="eyebrow">News &amp; Events</p>
    <h1>Life at Mt Cedar.</h1>
    <p>Celebrations, milestones and everyday moments from our school community.</p>
  </div>
</section>

<section class="news news-page">
  <div class="wrap">
    <div class="grid3">
      <article class="ncard"><div class="thumb"></div><div class="body"><span class="tag">Admissions</span><h3>2026/2027 admissions are now open</h3><p>Enrolment for the new session has begun across all stages. Book a visit to see the school for yourself.</p></div></article>
      <article class="ncard"><div class="thumb"></div><div class="body"><span class="tag">Event</span><h3>Founder’s Day &amp; cultural showcase</h3><p>A celebration of learning, character and community — pupils, parents and staff together.</p></div></article>
      <article class="ncard"><div class="thumb"></div><div class="body"><span class="tag">Achievement</span><h3>Our pupils shine in the science fair</h3><p>Young scientists present projects rooted in curiosity, care and real-world problem solving.</p></div></article>
      <article class="ncard"><div class="thumb"></div><div class="body"><span class="tag">Sport</span><h3>Inter-house games bring the school together</h3><p>A morning of friendly competition, teamwork and cheering — character in full flow on the field.</p></div></article>
      <article class="ncard"><div class="thumb"></div><div class="body"><span class="tag">Arts</span><h3>Young voices take the stage</h3><p>Music and drama from across the year groups, as pupils grow in confidence and creativity.</p></div></article>
      <article class="ncard"><div class="thumb"></div><div class="body"><span class="tag">Community</span><h3>Parents’ morning at Mt Cedar</h3><p>Families join us to see learning in action and partner with teachers in their children’s progress.</p></div></article>
    </div>
  </div>
</section>

<section class="band">
  <div class="wrap">
    <p class="eyebrow" style="color:var(--gold-bright)">Stay close to the school</p>
    <h2>Want to be part of it?</h2>
    <p>Admissions for 2026/2027 are open. Arrange a visit and see the Mt Cedar community for yourself.</p>
    <div class="cta">
      <a class="btn btn-gold btn-lg" href="/admissions">Explore Admissions <span class="arr">→</span></a>
      <a class="btn btn-ghost btn-lg" href="/contact">Contact Us</a>
    </div>
  </div>
</section>

</Layout>
